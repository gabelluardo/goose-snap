#!/bin/bash
# Snapd tab completion for goose.cli.
# Installed via the 'completer' key in snapcraft.yaml.
# Runs inside the snap sandbox, so use the snap-packaged goose binary.

_goose_cli() {
    local cur prev opts
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    opts="$($SNAP/bin/goose completion bash --bin-name goose.cli)"
    COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
    return 0
}
complete -F _goose_cli goose.cli
