#!/bin/bash
###############################################################################
# Launcher wrapper for the goose desktop (Electron) app inside a classic snap.
#
# Classic confinement gives the app full host access, so Electron's own
# chrome-sandbox (which relies on a SUID helper) cannot be used and must be
# disabled with --no-sandbox.
###############################################################################
set -euo pipefail

APP_ROOT="$SNAP/opt/goose-desktop"

# Keep only the app bundle at the front; forcing core24 libc paths here causes
# ABI mismatches on newer hosts (e.g. GLIBC_2.43 errors).
if [ -n "${LD_LIBRARY_PATH:-}" ]; then
	export LD_LIBRARY_PATH="$APP_ROOT:$LD_LIBRARY_PATH"
else
	export LD_LIBRARY_PATH="$APP_ROOT"
fi

# Ensure GTK/GSettings can resolve desktop schemas from the snap payload.
if [ -d "$SNAP/usr/share/glib-2.0/schemas" ]; then
	export GSETTINGS_SCHEMA_DIR="$SNAP/usr/share/glib-2.0/schemas"
fi
export XDG_DATA_DIRS="$SNAP/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

# Make host toolchains the agent shells out to (cargo, node, docker, uvx, ...)
# resolvable, while still preferring anything the snap ships.
export PATH="$SNAP/usr/bin:$SNAP/bin:$PATH"

# The packaged Electron executable is named after productName ("Goose").
electron_args=(
	--no-sandbox
)

# Use X11 by default to avoid Vulkan errors on Wayland; set
# GOOSE_OZONE_PLATFORM to override it.
if [ -n "${GOOSE_OZONE_PLATFORM:-x11}" ]; then
	electron_args+=(--ozone-platform="${GOOSE_OZONE_PLATFORM:-x11}")
fi

# Avoid leaking snap runtime env into the desktop process in classic confinement.
for var in $(env | cut -d= -f1 | grep '^SNAP'); do
	unset "$var"
done

exec "$APP_ROOT/Goose" "${electron_args[@]}" "$@"
